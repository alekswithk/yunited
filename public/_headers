# Cloudflare Pages reads this file from the repo root.
# Rules are matched in order and later matches win, so the general rule comes
# first and the more specific paths override it below.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  # 'unsafe-inline' is unavoidable for now: the pages carry inline style="…"
  # attributes, inline JSON-LD, and the inline form-validation script on
  # contact.html. The policy still pins every *external* origin we allow.
  # static.cloudflareinsights.com is the Cloudflare Web Analytics beacon.
  # formspree.io needs both connect-src (the contact form's fetch submit) and
  # form-action (the no-JS fallback, which posts the form natively).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com https://formspree.io; form-action 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# Nothing here is content-hashed — there is no build step — so a long cache on
# the stylesheet or scripts would strand returning visitors on a stale design.
# Let these revalidate against their ETag instead; they are a few KB each.
/css/*
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=0, must-revalidate

# The board edits these to publish events and board changes. Keep the window
# short so a push shows up almost immediately.
/content/*
  Cache-Control: public, max-age=60, must-revalidate

/assets/*
  Cache-Control: public, max-age=86400

# Font filenames encode family, weight, style and subset, so they only change
# when the font itself is regenerated. Safe to hold on to.
/assets/fonts/*
  Cache-Control: public, max-age=2592000, immutable
