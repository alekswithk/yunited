# Cloudflare Pages reads this file from the repo root.
# Rules are matched in order and later matches win, so the general rule comes
# first and the more specific paths override it below.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  # 'unsafe-inline' is unavoidable for now: the pages carry inline style="…"
  # attributes, inline JSON-LD, and the inline form-validation script on
  # contact.html. The policy still pins every *external* origin we allow.
  # static.cloudflareinsights.com is the Cloudflare Web Analytics beacon.
  # formspree.io needs both connect-src (the contact form's fetch submit) and
  # form-action (the no-JS fallback, which posts the form natively).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com https://formspree.io; form-action 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# Astro fingerprints everything it emits here — the stylesheet, optimized
# images, page scripts — with a content hash in the filename, so a given URL
# never changes meaning. Cache it forever; a new build ships new filenames.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=86400

# Font filenames encode family, weight, style and subset, so they only change
# when the font itself is regenerated. Safe to hold on to.
/assets/fonts/*
  Cache-Control: public, max-age=2592000, immutable

# The CMS admin app (Sveltia SPA) needs a looser policy than the public site: it
# talks to the GitHub API, runs a bundled single-page app, and loads its icon
# font (Material Symbols) + UI fonts from Google Fonts — without fonts.googleapis
# (the font CSS) and fonts.gstatic (the font files) the toolbar icons render as
# raw text like "cloud_upload". This is scoped to /admin only; the public site
# keeps its strict, fully self-hosted-font CSP. Cloudflare COMBINES a repeated
# header across matching rules (intersecting the two CSPs, which would block the
# CMS), so "! Content-Security-Policy" first drops the global /* policy, then we
# set this admin-only one.
# If something still fails with a CSP violation in the browser console, add the
# named origin here (see docs/CMS.md).
/admin/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.githubusercontent.com https://avatars.githubusercontent.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.github.com https://*.githubusercontent.com https://*.workers.dev; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self' https://github.com
  X-Robots-Tag: noindex
