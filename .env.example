# Copy this file to .env and fill in your key. .env is gitignored — it is
# never committed. Only used by `npm run translate` (see scripts/translate.mjs);
# the site build never reads it.

# DeepL API key. Get one at https://www.deepl.com/pro-api — the free tier's
# 500k chars/month is far more than this site needs. Free-tier keys end in ":fx".
DEEPL_API_KEY=
