---
// The single source of truth for every page's <head> and page chrome.
// Props: title, description, path (route, for canonical + active nav),
// and noindex (for 404). A named "head" slot lets a page inject extra
// tags such as JSON-LD.
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { defaultLocale, getLocale, localizePath, publishedLocales } from "../i18n/config.js";
import "../styles/global.css";

const {
  title,
  description,
  path = "/",
  locale = defaultLocale,
  noindex = false,
} = Astro.props;

const loc = getLocale(locale);
const canonical = new URL(localizePath(path, loc.code), Astro.site).href;
const ogImage = new URL("/assets/og-image.png", Astro.site).href;

// Only finished translations are advertised to crawlers. An in-progress locale
// still renders (so it can be reviewed at its real URL) but is kept out of the
// alternates and marked noindex, so a half-translated page is never indexed.
const alternates = publishedLocales();
const showAlternates = alternates.length > 1;
const hideFromIndex = noindex || !loc.complete;
---

<!DOCTYPE html>
<html lang={loc.htmlLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  {hideFromIndex && <meta name="robots" content="noindex">}

  <link rel="canonical" href={canonical}>

  {showAlternates && alternates.map((l) => (
    <link rel="alternate" hreflang={l.code} href={new URL(localizePath(path, l.code), Astro.site).href}>
  ))}
  {showAlternates && (
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath(path, defaultLocale), Astro.site).href}>
  )}

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="YUnited">
  <meta property="og:locale" content={loc.ogLocale}>
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="The YUnited wordmark on a cream background with a kilim diamond motif">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="icon" type="image/svg+xml" href="/assets/yunited-favicon.svg">
  <link rel="alternate icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/icon-192.png">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#f4ecdd">
  <link rel="preload" href="/assets/fonts/fraunces-400-900-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/newsreader-400-600-normal-latin.woff2" as="font" type="font/woff2" crossorigin>

  <slot name="head" />
</head>
<body>

  <Header path={path} locale={loc.code} />

  <main>
    <slot />
  </main>

  <div class="motif-divider" role="presentation"></div>

  <Footer locale={loc.code} />

  <script>
    // Shared behaviours from the old main.js: mobile menu toggle and
    // reveal-on-scroll. The footer year is now rendered at build time.

    // --- Mobile menu toggle ---
    const navToggleButton = document.querySelector(".nav-toggle");
    const mainNav = document.querySelector(".main-nav");

    if (navToggleButton && mainNav) {
      navToggleButton.addEventListener("click", () => {
        const isOpen = mainNav.classList.toggle("is-open");
        navToggleButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });
    }

    // --- Reveal sections as they scroll into view ---
    const revealElements = document.querySelectorAll(".reveal");

    if ("IntersectionObserver" in window && revealElements.length > 0) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      revealElements.forEach((element) => revealObserver.observe(element));
    } else {
      revealElements.forEach((element) => element.classList.add("is-visible"));
    }

    // --- Table-of-contents scroll spy ---
    // Marks the entry for whichever section is currently nearest the top of the
    // viewport. Without JS the links still work as plain anchors; they just
    // don't highlight. aria-current is the single source of truth here, so what
    // is announced and what is styled can never drift apart.
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");

    if (tocLinks.length > 0 && "IntersectionObserver" in window) {
      const linkFor = new Map<string, HTMLAnchorElement>();
      const watched: Element[] = [];

      tocLinks.forEach((link) => {
        const id = link.dataset.tocLink;
        if (!id) return;
        const section = document.getElementById(id);
        if (!section) return; // a TOC entry naming a section that isn't here
        linkFor.set(id, link);
        watched.push(section);
      });

      const onScreen = new Set<string>();

      const setCurrent = (id: string | null) => {
        linkFor.forEach((link, key) => {
          if (key === id) link.setAttribute("aria-current", "true");
          else link.removeAttribute("aria-current");
        });
      };

      const tocObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) onScreen.add(entry.target.id);
            else onScreen.delete(entry.target.id);
          }
          // Several sections can be in view at once; the topmost one in document
          // order is the one you are actually reading.
          const first = watched.find((section) => onScreen.has(section.id));
          setCurrent(first ? first.id : null);
        },
        // Bias the band toward the upper part of the viewport so the highlight
        // moves when a heading reaches reading position, not when it exits.
        { rootMargin: "-20% 0px -70% 0px" }
      );

      watched.forEach((section) => tocObserver.observe(section));
    }
  </script>
</body>
</html>
