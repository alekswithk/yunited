---
// The single source of truth for every page's <head> and page chrome.
// Props: title, description, path (route, for canonical + active nav),
// and noindex (for 404). A named "head" slot lets a page inject extra
// tags such as JSON-LD.
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { defaultLocale, getLocale, localizePath, publishedLocales } from "../i18n/config.js";
import "../styles/global.css";

const {
  title,
  description,
  path = "/",
  locale = defaultLocale,
  noindex = false,
} = Astro.props;

const loc = getLocale(locale);
const canonical = new URL(localizePath(path, loc.code), Astro.site).href;
const ogImage = new URL("/assets/og-image.png", Astro.site).href;

// Only finished translations are advertised to crawlers. An in-progress locale
// still renders (so it can be reviewed at its real URL) but is kept out of the
// alternates and marked noindex, so a half-translated page is never indexed.
const alternates = publishedLocales();
const showAlternates = alternates.length > 1;
const hideFromIndex = noindex || !loc.complete;
---

<!DOCTYPE html>
<html lang={loc.htmlLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  {hideFromIndex && <meta name="robots" content="noindex">}

  <link rel="canonical" href={canonical}>

  {showAlternates && alternates.map((l) => (
    <link rel="alternate" hreflang={l.code} href={new URL(localizePath(path, l.code), Astro.site).href}>
  ))}
  {showAlternates && (
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath(path, defaultLocale), Astro.site).href}>
  )}

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="YUnited">
  <meta property="og:locale" content={loc.ogLocale}>
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="The YUnited wordmark on a cream background with a kilim diamond motif">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="icon" type="image/svg+xml" href="/assets/yunited-favicon.svg">
  <link rel="alternate icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/icon-192.png">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#f4ecdd">
  <link rel="preload" href="/assets/fonts/fraunces-400-900-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/newsreader-400-600-normal-latin.woff2" as="font" type="font/woff2" crossorigin>

  <slot name="head" />
</head>
<body>

  <Header path={path} locale={loc.code} />

  <main>
    <slot />
  </main>

  <div class="motif-divider" role="presentation"></div>

  <Footer locale={loc.code} />

  <script>
    // Shared behaviours from the old main.js: mobile menu toggle and
    // reveal-on-scroll. The footer year is now rendered at build time.

    // --- Mobile menu toggle ---
    const navToggleButton = document.querySelector(".nav-toggle");
    const mainNav = document.querySelector(".main-nav");

    if (navToggleButton && mainNav) {
      navToggleButton.addEventListener("click", () => {
        const isOpen = mainNav.classList.toggle("is-open");
        navToggleButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });
    }

    // --- Language switcher: close on outside click and on Escape ---
    // <details> handles opening, focus and keyboard activation itself; these are
    // the only two behaviours it doesn't provide. With JS off the menu still
    // opens and closes on click, which is why it's a disclosure and not a
    // scripted dropdown.
    const langSwitch = document.querySelector<HTMLDetailsElement>(".lang-switch");

    if (langSwitch) {
      document.addEventListener("click", (event) => {
        const target = event.target as Node | null;
        if (langSwitch.open && target && !langSwitch.contains(target)) {
          langSwitch.open = false;
        }
      });

      langSwitch.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && langSwitch.open) {
          langSwitch.open = false;
          langSwitch.querySelector("summary")?.focus();
        }
      });
    }

    // --- Reveal sections as they scroll into view ---
    const revealElements = document.querySelectorAll(".reveal");

    if ("IntersectionObserver" in window && revealElements.length > 0) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      revealElements.forEach((element) => revealObserver.observe(element));
    } else {
      revealElements.forEach((element) => element.classList.add("is-visible"));
    }

    // --- Table-of-contents scroll spy ---
    // Marks the entry for whichever section is currently nearest the top of the
    // viewport. Without JS the links still work as plain anchors; they just
    // don't highlight. aria-current is the single source of truth here, so what
    // is announced and what is styled can never drift apart.
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");

    if (tocLinks.length > 0 && "IntersectionObserver" in window) {
      const linkFor = new Map<string, HTMLAnchorElement>();
      const watched: Element[] = [];

      tocLinks.forEach((link) => {
        const id = link.dataset.tocLink;
        if (!id) return;
        const section = document.getElementById(id);
        if (!section) return; // a TOC entry naming a section that isn't here
        linkFor.set(id, link);
        watched.push(section);
      });

      const onScreen = new Set<string>();

      const setCurrent = (id: string | null) => {
        linkFor.forEach((link, key) => {
          if (key === id) link.setAttribute("aria-current", "true");
          else link.removeAttribute("aria-current");
        });
      };

      const tocObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) onScreen.add(entry.target.id);
            else onScreen.delete(entry.target.id);
          }
          // Several sections can be in view at once; the topmost one in document
          // order is the one you are actually reading.
          const first = watched.find((section) => onScreen.has(section.id));
          setCurrent(first ? first.id : null);
        },
        // Bias the band toward the upper part of the viewport so the highlight
        // moves when a heading reaches reading position, not when it exits.
        { rootMargin: "-20% 0px -70% 0px" }
      );

      watched.forEach((section) => tocObserver.observe(section));

      // --- Keep each TOC entry legible against what is behind it ---
      // The rail is position:fixed, so the page scrolls dark sections under it
      // and its dark inks disappear. Each link gets its own observer whose root
      // is collapsed — via rootMargin — to a band at exactly that link's
      // vertical position, watching only the dark surfaces. When one is inside
      // that band, ink is behind THAT link and it flips to the paper palette.
      //
      // Deliberately not reusing tocObserver above: its "-20% 0px -70%" root
      // samples the upper viewport to decide what you are *reading*, while the
      // rail sits at the centre. They measure different things.
      //
      // Per link rather than per rail because the rail is ~150px tall: at a
      // section boundary a single toggle would always leave one end of it
      // unreadable, which is the bug this fixes.
      const darkSurfaces = document.querySelectorAll(
        ".hero, .page-hero, .section-dark, .site-footer"
      );

      if (darkSurfaces.length > 0) {
        let backdropObservers: IntersectionObserver[] = [];

        const watchBackdrops = () => {
          backdropObservers.forEach((o) => o.disconnect());
          backdropObservers = [];

          tocLinks.forEach((link) => {
            const box = link.getBoundingClientRect();
            // Zero height means the rail is hidden (below 1100px) — nothing to do.
            if (box.height === 0) return;

            const above = Math.round(box.top);
            const below = Math.round(window.innerHeight - box.bottom);

            // Track which dark surfaces are in this link's band. A Set rather
            // than a counter: the first callback reports every observed element
            // at once, so add/delete stays correct where +1/-1 would not.
            const behind = new Set<Element>();

            const observer = new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  if (entry.isIntersecting) behind.add(entry.target);
                  else behind.delete(entry.target);
                }
                link.classList.toggle("is-on-dark", behind.size > 0);
              },
              { rootMargin: `-${above}px 0px -${below}px 0px` }
            );

            darkSurfaces.forEach((surface) => observer.observe(surface));
            backdropObservers.push(observer);
          });
        };

        watchBackdrops();

        // The bands are absolute pixel offsets measured from the rail, so they
        // go stale whenever the rail moves or resizes. Two things do that:
        //
        // 1. The viewport resizing — the rail is vertically centred.
        // 2. Webfonts swapping in. The rail is set in Space Mono with
        //    font-display: swap, so its height changes when the real font
        //    arrives, which is usually AFTER this script first runs.
        let pending = 0;
        const rebuild = () => {
          cancelAnimationFrame(pending);
          pending = requestAnimationFrame(watchBackdrops);
        };

        window.addEventListener("resize", rebuild);
        document.fonts?.ready.then(rebuild);
      }
    }
  </script>
</body>
</html>
