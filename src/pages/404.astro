---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found — Yunited" description="The page you were looking for doesn't exist." path="/404" noindex={true}>
  <section class="error-page">
    <div class="container">
      <p class="error-code">404</p>
      <h1>Nema te stranice — page not found.</h1>
      <p style="color: var(--color-muted); margin-bottom: var(--space-5);">
        The page you're looking for doesn't exist (or moved). Let's get you
        back to the party.
      </p>
      <a class="btn btn-red" href="/">Back to home</a>
    </div>
  </section>
</BaseLayout>
