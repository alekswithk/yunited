---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventCard from "../components/EventCard.astro";
import events from "../../content/events.json";
import { splitEvents } from "../lib/events.js";

const { upcoming, past } = splitEvents(events);

const title = "Events — Yunited";
const description =
  "Upcoming events and past-event recaps from Yunited, the Balkan & ex-Yu student club at HSG.";
---

<BaseLayout title={title} description={description} path="/events">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">Događaji · Догађаји · Events</p>
      <h1>Events</h1>
      <p>Brunches, barbecues, karaoke, casino nights and career events —
      this is what we get up to. Members get access to all events via
      uniclubs.</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <p class="eyebrow">Save the date</p>
      <h2>Upcoming events</h2>
      <div class="magazine-grid" id="upcoming-events">
        {upcoming.length > 0 ? (
          upcoming.map((event) => <EventCard event={event} isPast={false} />)
        ) : (
          <p class="empty-note">No upcoming events are scheduled right now — follow us on Instagram (@yunited.unisg) or check uniclubs to be first to hear about the next one.</p>
        )}
      </div>
    </div>
  </section>

  <section>
    <div class="container reveal">
      <p class="eyebrow">Recaps</p>
      <h2>Past events</h2>
      <p class="section-intro">A look back at what we've done recently.
      Photos and stories also live on our <a href="https://www.instagram.com/yunited.unisg" target="_blank" rel="noopener">Instagram</a>.</p>
      <div class="magazine-grid" id="past-events">
        {past.length > 0 ? (
          past.map((event) => <EventCard event={event} isPast={true} />)
        ) : (
          <p class="empty-note">No past events yet.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
