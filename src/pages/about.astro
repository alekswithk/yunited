---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "About — Yunited";
const description =
  "Yunited fosters cultural exchange between students from former Yugoslavia at the University of St. Gallen. Founded 2013.";
---

<BaseLayout title={title} description={description} path="/about">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">O nama · О нама · About us</p>
      <h1>About Yunited</h1>
      <p>Fostering cultural exchange between students from former Yugoslavia
      at the University of St. Gallen — since 2013.</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <p class="eyebrow">Our mission</p>
      <h2>What we do</h2>
      <div style="max-width: 680px;">
        <p style="margin-bottom: var(--space-3);">
          Yunited connects students with roots from former Yugoslavia socially
          and professionally while fostering cultural exchange at the
          University of St. Gallen.
        </p>
        <p style="margin-bottom: var(--space-3);">
          We host a variety of social and professional events for students from
          ex-Yugoslav countries to aid in their personal and professional
          development during and after their studies at HSG — and everyone
          interested in the culture is welcome, whether or not your roots are
          in the region.
        </p>
        <p style="margin-bottom: var(--space-3);">
          Beyond campus, Yunited builds a network between students, supports
          their academic development, acts as a bridge to companies and
          organisations with an ex-Yugoslav background, and supports and
          promotes fundraising campaigns.
        </p>
        <p>
          Our buddy-system offers guidance for assessment and exchange
          students while fostering connections across all majors and
          semesters.
        </p>
      </div>
    </div>
  </section>

  <section class="section-dark">
    <div class="container reveal">
      <p class="eyebrow">Since 2013</p>
      <h2>Our story</h2>
      <p class="section-intro">
        Yunited was founded in 2013 as the cultural club for students from the
        ex-Yugoslav region at HSG.
      </p>
    </div>
  </section>

  <section>
    <div class="container reveal">
      <p class="eyebrow">Values</p>
      <h2>What we stand for</h2>
      <div class="split-grid">
        <div class="info-panel panel-red">
          <h3>Community</h3>
          <p>A home away from home: friendships across all majors and
          semesters, from the Assessment year to Master's and beyond.</p>
        </div>
        <div class="info-panel">
          <h3>Culture</h3>
          <p>Keeping the food, music, humour and traditions of the region
          alive in St. Gallen — and sharing them with everyone who's curious.</p>
        </div>
        <div class="info-panel" style="border-top-color: var(--color-gold);">
          <h3>Careers</h3>
          <p>Professional events and a bridge to companies and organisations
          with ex-Yugoslav roots, during your studies and after them.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
