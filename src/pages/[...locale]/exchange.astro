---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localePaths, localizePath } from "../../i18n/config.js";
import { useTranslations } from "../../i18n/utils.js";

export const getStaticPaths = localePaths;

const { locale } = Astro.params;
const t = useTranslations(locale);

const title = t("meta.exchange.title");
const description = t("meta.exchange.description");
---

<BaseLayout locale={locale} title={title} description={description} path="/exchange">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">Razmena · Размена · Exchange</p>
      <h1>Exchange students</h1>
      <p>Whether you're arriving at HSG for a semester or heading abroad
      yourself — here's how Yunited fits into your exchange.</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <div class="split-grid">

        <!-- Audience 1: incoming exchange students -->
        <div class="info-panel panel-red">
          <p class="eyebrow">Coming to HSG</p>
          <h3>Incoming exchange students</h3>
          <p>Spending a semester in St. Gallen? You're warmly invited —
          no Balkan roots required.</p>
          <ul>
            <li><strong>Buddy-system:</strong> our buddy-system offers
            guidance for assessment and exchange students — a friendly
            first contact for questions about HSG and life in St. Gallen.</li>
            <li><strong>Events:</strong> join our brunches, barbecues,
            karaoke and party nights from week one. Membership (via
            uniclubs) gives access to all events.</li>
            <li><strong>A taste of home:</strong> if your roots are in the
            region, we're a way to stay connected to the culture while
            abroad. If not, we're a fun way to discover it.</li>
          </ul>
          <p style="margin-top: var(--space-4);">
            <a class="btn btn-red" href={localizePath("/contact", locale)}>Ask us anything</a>
          </p>
        </div>

        <!-- Audience 2: outgoing HSG students -->
        <div class="info-panel">
          <p class="eyebrow" style="color: var(--color-azure);">Going abroad</p>
          <h3>Outgoing HSG students</h3>
          <p>Off on exchange — to Rotterdam, Vienna, Singapore or anywhere
          else? Here's the honest picture:</p>
          <ul>
            <li>Yunited doesn't currently run a formal programme for
            students abroad.</li>
            <li>Members often stay in the loop informally — follow
            <a href="https://www.instagram.com/yunited.unisg" target="_blank" rel="noopener">@yunited.unisg</a>
            to keep up with the community while you're away.</li>
            <li>Happy to share tips: if a Yunited member has studied at
            your destination, we'll gladly connect you — just
            <a href={localizePath("/contact", locale)}>reach out</a>.</li>
          </ul>
          <p style="margin-top: var(--space-4);">
            <a class="btn btn-outline" href={localizePath("/contact", locale)}>Stay in touch</a>
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
