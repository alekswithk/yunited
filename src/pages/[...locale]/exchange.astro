---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localePaths, localizePath } from "../../i18n/config.js";
import { useTranslations } from "../../i18n/utils.js";

export const getStaticPaths = localePaths;

const { locale } = Astro.params;
const t = useTranslations(locale);

const title = t("meta.exchange.title");
const description = t("meta.exchange.description");
---

<BaseLayout locale={locale} title={title} description={description} path="/exchange">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">Razmena · Размена · Exchange</p>
      <h1>{t("exchange.heroTitle")}</h1>
      <p>{t("exchange.heroLede")}</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <div class="split-grid">

        <!-- Audience 1: incoming exchange students -->
        <div class="info-panel panel-red">
          <p class="eyebrow">{t("exchange.incomingEyebrow")}</p>
          <h3>{t("exchange.incomingHeading")}</h3>
          <p>{t("exchange.incomingLede")}</p>
          <ul>
            <li set:html={t("exchange.incomingBuddy")}></li>
            <li set:html={t("exchange.incomingEvents")}></li>
            <li set:html={t("exchange.incomingHome")}></li>
          </ul>
          <p style="margin-top: var(--space-4);">
            <a class="btn btn-red" href={localizePath("/contact", locale)}>{t("exchange.incomingCta")}</a>
          </p>
        </div>

        <!-- Audience 2: outgoing HSG students -->
        <div class="info-panel">
          <p class="eyebrow" style="color: var(--color-azure);">{t("exchange.outgoingEyebrow")}</p>
          <h3>{t("exchange.outgoingHeading")}</h3>
          <p>{t("exchange.outgoingLede")}</p>
          <ul>
            <li>{t("exchange.outgoingItem1")}</li>
            <li set:html={t("exchange.outgoingItem2")}></li>
            <li>{t("exchange.outgoingItem3Pre")}<a href={localizePath("/contact", locale)}>{t("exchange.outgoingItem3Link")}</a>{t("exchange.outgoingItem3Post")}</li>
          </ul>
          <p style="margin-top: var(--space-4);">
            <a class="btn btn-outline" href={localizePath("/contact", locale)}>{t("exchange.outgoingCta")}</a>
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
