---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localePaths, localizePath } from "../../i18n/config.js";
import { useTranslations } from "../../i18n/utils.js";

export const getStaticPaths = localePaths;

const { locale } = Astro.params;
const t = useTranslations(locale);

const title = t("meta.join.title");
const description = t("meta.join.description");
---

<BaseLayout locale={locale} title={title} description={description} path="/join">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">Pridruži se · Придружи се · Join us</p>
      <h1>{t("join.heroTitle")}</h1>
      <p>{t("join.heroLede")}</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <p class="eyebrow">{t("join.getEyebrow")}</p>
      <h2>{t("join.getHeading")}</h2>
      <div class="split-grid" style="max-width: 860px;">
        <div class="info-panel panel-red">
          <h3>{t("join.semesterTitle")}</h3>
          <p set:html={t("join.semesterBody")}></p>
        </div>
        <div class="info-panel" style="border-top-color: var(--color-gold);">
          <h3>{t("join.freeTitle")}</h3>
          <p set:html={t("join.freeBody")}></p>
        </div>
      </div>
      <p style="margin-top: var(--space-5);">
        <a class="btn btn-red" href="https://uniclubs.ch/hsg/clubs/yunited" target="_blank" rel="noopener">
          {t("join.cta")}
        </a>
      </p>
      <p class="form-note" style="margin-top: var(--space-3);">
        {t("join.note")}
      </p>
    </div>
  </section>

  <section class="section-dark">
    <div class="container reveal">
      <h2>{t("join.questionsHeading")}</h2>
      <p class="section-intro">{t("join.questionsBody")}</p>
      <a class="btn btn-gold" href={localizePath("/contact", locale)}>{t("join.questionsCta")}</a>
    </div>
  </section>
</BaseLayout>
