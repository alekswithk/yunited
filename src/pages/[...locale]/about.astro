---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localePaths } from "../../i18n/config.js";
import { useTranslations } from "../../i18n/utils.js";

export const getStaticPaths = localePaths;

const { locale } = Astro.params;
const t = useTranslations(locale);

const title = t("meta.about.title");
const description = t("meta.about.description");
---

<BaseLayout locale={locale} title={title} description={description} path="/about">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">O nama · О нама · About us</p>
      <h1>{t("about.heroTitle")}</h1>
      <p>{t("about.heroLede")}</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <p class="eyebrow">{t("about.missionEyebrow")}</p>
      <h2>{t("about.missionHeading")}</h2>
      <div style="max-width: 680px;">
        <p style="margin-bottom: var(--space-3);">{t("about.missionP1")}</p>
        <p style="margin-bottom: var(--space-3);">{t("about.missionP2")}</p>
        <p style="margin-bottom: var(--space-3);">{t("about.missionP3")}</p>
        <p>{t("about.missionP4")}</p>
      </div>
    </div>
  </section>

  <section class="section-dark">
    <div class="container reveal">
      <p class="eyebrow">{t("about.storyEyebrow")}</p>
      <h2>{t("about.storyHeading")}</h2>
      <p class="section-intro">{t("about.storyIntro")}</p>
    </div>
  </section>

  <section>
    <div class="container reveal">
      <p class="eyebrow">{t("about.valuesEyebrow")}</p>
      <h2>{t("about.valuesHeading")}</h2>
      <div class="split-grid">
        <div class="info-panel panel-red">
          <h3>{t("about.valueCommunityTitle")}</h3>
          <p>{t("about.valueCommunityBody")}</p>
        </div>
        <div class="info-panel">
          <h3>{t("about.valueCultureTitle")}</h3>
          <p>{t("about.valueCultureBody")}</p>
        </div>
        <div class="info-panel" style="border-top-color: var(--color-gold);">
          <h3>{t("about.valueCareersTitle")}</h3>
          <p>{t("about.valueCareersBody")}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
