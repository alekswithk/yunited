---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MemberLead from "../../components/MemberLead.astro";
import MemberRow from "../../components/MemberRow.astro";
import { members } from "../../lib/content.js";
import { localePaths, localizePath } from "../../i18n/config.js";
import { useTranslations } from "../../i18n/utils.js";

export const getStaticPaths = localePaths;

const { locale } = Astro.params;
const t = useTranslations(locale);

const title = t("meta.members.title");
const description = t("meta.members.description");

const [lead, ...roster] = Array.isArray(members) ? members : [];
---

<BaseLayout locale={locale} title={title} description={description} path="/members">
  <section class="page-hero">
    <div class="container">
      <p class="hero-script">Naš tim · Наш тим · Our team</p>
      <h1>{t("members.heroTitle")}</h1>
      <p>{t("members.heroLede")}</p>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <section>
    <div class="container reveal">
      <p class="eyebrow">{t("members.boardEyebrow")}</p>
      <h2>{t("members.boardHeading")}</h2>
      <div id="member-grid">
        {lead ? (
          <>
            <MemberLead member={lead} />
            {roster.length > 0 && (
              <div class="roster">
                {roster.map((member) => <MemberRow member={member} />)}
              </div>
            )}
          </>
        ) : (
          <p class="empty-note">{t("members.boardEmpty")}</p>
        )}
      </div>
    </div>
  </section>

  <section class="section-dark">
    <div class="container reveal">
      <h2>{t("members.involvedHeading")}</h2>
      <p class="section-intro">{t("members.involvedBody")}</p>
      <a class="btn btn-gold" href={localizePath("/contact", locale)}>{t("members.involvedCta")}</a>
    </div>
  </section>
</BaseLayout>
