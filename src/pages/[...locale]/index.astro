---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageToc from "../../components/PageToc.astro";
import EventCard from "../../components/EventCard.astro";
import { events } from "../../lib/content.js";
import { splitEvents } from "../../lib/events.js";
import { localePaths, localizePath } from "../../i18n/config.js";
import { useTranslations } from "../../i18n/utils.js";

export const getStaticPaths = localePaths;

const { locale } = Astro.params;
const t = useTranslations(locale);

const { upcoming, past } = splitEvents(events);
const upcomingTeaser = upcoming.slice(0, 2);
const pastTeaser = past.slice(0, 2);

const title = t("meta.home.title");
const description = t("meta.home.description");

// Each id must match a <section id> below. The hero is deliberately not listed
// — you are already there when the page loads.
const sections = [
  { id: "upcoming", key: "toc.upcoming" },
  { id: "recent", key: "toc.recent" },
  { id: "who", key: "toc.who" },
];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "YUnited",
  url: "https://yunited.ch",
  logo: "https://yunited.ch/assets/yunited-logo.svg",
  image: "https://yunited.ch/assets/og-image.png",
  email: "yunited@shsg.ch",
  foundingDate: "2013",
  description,
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: "University of St. Gallen",
    url: "https://www.unisg.ch",
  },
  areaServed: { "@type": "City", name: "St. Gallen" },
  sameAs: [
    "https://www.instagram.com/yunited.unisg",
    "https://www.linkedin.com/company/yunited-unisg",
    "https://uniclubs.ch/hsg/clubs/yunited",
  ],
};
---

<BaseLayout locale={locale} title={title} description={description} path="/">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} slot="head" />

  <!-- Hero: answers "what is this" immediately, no info gated behind animation -->
  <PageToc sections={sections} locale={locale} label="toc.aria" />

  <section class="hero">
    <div class="container">
      <p class="hero-script">Dobrodošli · Добродошли · Welcome</p>
      <h1>{t("home.heroTitleMain")} <span class="accent">{t("home.heroTitleAccent")}</span></h1>
      <p class="lede">{t("home.heroLede")}</p>
      <div class="hero-actions">
        <a class="btn btn-gold" href={localizePath("/join", locale)}>{t("home.heroJoin")}</a>
        <a class="btn btn-red" href={localizePath("/events", locale)}>{t("home.heroEvents")}</a>
      </div>
    </div>
  </section>

  <div class="motif-divider" role="presentation"></div>

  <!-- Upcoming events teaser (max 2, rendered from content/events.json) -->
  <section id="upcoming">
    <div class="container reveal">
      <p class="eyebrow">{t("home.upcomingEyebrow")}</p>
      <h2>{t("home.upcomingHeading")}</h2>
      <div class="card-grid" id="upcoming-events">
        {upcomingTeaser.length > 0 ? (
          upcomingTeaser.map((event) => <EventCard event={event} isPast={false} locale={locale} />)
        ) : (
          <p class="empty-note">{t("events.emptyUpcoming")}</p>
        )}
      </div>
    </div>
  </section>

  <!-- Recent past-event highlights (max 2, same JSON, same card) -->
  <section id="recent">
    <div class="container reveal">
      <p class="eyebrow">{t("home.pastEyebrow")}</p>
      <h2>{t("home.pastHeading")}</h2>
      <div class="card-grid" id="past-events">
        {pastTeaser.length > 0 ? (
          pastTeaser.map((event) => <EventCard event={event} isPast={true} locale={locale} />)
        ) : (
          <p class="empty-note">{t("events.emptyPast")}</p>
        )}
      </div>
      <p style="margin-top: var(--space-4);">
        <a class="btn btn-outline" href={localizePath("/events", locale)}>{t("home.allEvents")}</a>
      </p>
    </div>
  </section>

  <!-- Short "what we stand for" teaser linking to About -->
  <section id="who" class="section-dark">
    <div class="container reveal">
      <p class="eyebrow">{t("home.whoEyebrow")}</p>
      <h2>{t("home.whoHeading")}</h2>
      <p class="section-intro">{t("home.whoBody")}</p>
      <a class="btn btn-gold" href={localizePath("/about", locale)}>{t("home.whoCta")}</a>
    </div>
  </section>
</BaseLayout>
