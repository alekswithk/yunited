---
// The site footer, rendered once for every page. The year is computed at
// build time (was set client-side by main.js).
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h3>Yunited</h3>
        <p>HSG student club connecting students with Balkan and ex-Yugoslav
        roots — and everyone curious about the culture — since 2013.</p>
      </div>
      <div>
        <h3>Pages</h3>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/members">Members</a></li>
          <li><a href="/exchange">Exchange students</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3>Connect</h3>
        <ul>
          <li><a href="https://www.instagram.com/yunited.unisg" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://www.linkedin.com/company/yunited-unisg" target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href="mailto:yunited@shsg.ch">yunited@shsg.ch</a></li>
          <li><a href="https://uniclubs.ch/hsg/clubs/yunited" target="_blank" rel="noopener">Join on uniclubs</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {year} Yunited — a student club at the University
      of St. Gallen (HSG). Membership is managed on
      <a href="https://uniclubs.ch/hsg/clubs/yunited" target="_blank" rel="noopener">uniclubs.ch</a>.</p>
    </div>
  </div>
</footer>
