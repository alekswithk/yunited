---
// The site footer, rendered once for every page. The year is computed at
// build time (was set client-side by main.js).
import { defaultLocale, localizePath } from "../i18n/config.js";
import { useTranslations } from "../i18n/utils.js";

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h3>Yunited</h3>
        <p>{t("footer.tagline")}</p>
      </div>
      <div>
        <h3>{t("footer.pages")}</h3>
        <ul>
          <li><a href={localizePath("/about", locale)}>{t("nav.about")}</a></li>
          <li><a href={localizePath("/events", locale)}>{t("nav.events")}</a></li>
          <li><a href={localizePath("/members", locale)}>{t("nav.members")}</a></li>
          <li><a href={localizePath("/exchange", locale)}>{t("footer.exchangeLink")}</a></li>
          <li><a href={localizePath("/contact", locale)}>{t("nav.contact")}</a></li>
        </ul>
      </div>
      <div>
        <h3>{t("footer.connect")}</h3>
        <ul>
          <li><a href="https://www.instagram.com/yunited.unisg" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://www.linkedin.com/company/yunited-unisg" target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href="mailto:yunited@shsg.ch">yunited@shsg.ch</a></li>
          <li><a href="https://uniclubs.ch/hsg/clubs/yunited" target="_blank" rel="noopener">{t("footer.joinOnUniclubs")}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {year} Yunited — {t("footer.rights")}
      <a href="https://uniclubs.ch/hsg/clubs/yunited" target="_blank" rel="noopener">uniclubs.ch</a>.</p>
    </div>
  </div>
</footer>
