---
// One event card, rendered at build time (was buildEventCard in events.js).
// The same template serves upcoming and past events. Astro escapes every
// interpolated value, so the old manual escapeHtml is no longer needed.
import { Image } from "astro:assets";
import { formatEventDate } from "../lib/events.js";
import { resolveImage } from "../lib/images.js";
import { localizeEntry } from "../lib/content.js";
import { defaultLocale, getLocale } from "../i18n/config.js";
import { useTranslations } from "../i18n/utils.js";

const { event: sourceEvent, isPast = false, locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
const loc = getLocale(locale);
// Title/description come from the entry's own translation block when the board's
// content has been translated into this locale; otherwise the authored text.
const event = localizeEntry(sourceEvent, loc.dict);

const image = resolveImage(event.image);
const timeText = event.time ? " · " + event.time : "";
const hasRsvp = event.rsvpUrl && /^https:\/\//i.test(event.rsvpUrl);
const linkText = isPast ? t("events.pastCta") : t("events.rsvpCta");
// Month names follow the locale: "13 May 2026" in English, "13. Mai 2026" in German.
const dateText = formatEventDate(event.date, getLocale(locale).dateLocale) ?? t("events.dateTba");
---

<article class="card reveal is-visible">
  {image ? (
    <div class="card-image">
      <Image src={image} alt={t("events.photoAlt", { title: event.title })} width={480} densities={[1, 2]} loading="lazy" />
    </div>
  ) : (
    <div class="card-image" aria-hidden="true">{event.title.charAt(0).toUpperCase()}</div>
  )}
  <div class="card-body">
    <p class="card-date">{dateText}{timeText}</p>
    <h3>{event.title}</h3>
    <p class="card-location">{event.location ?? t("events.locationTba")}</p>
    <p class="card-description">{event.description}</p>
    {hasRsvp && (
      <a class="card-link" href={event.rsvpUrl} target="_blank" rel="noopener">{linkText}</a>
    )}
  </div>
</article>
